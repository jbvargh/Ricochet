# TerpSpark — local environment template
#
# Copy this file to `.env.local` and fill in values:
#   cp .env.local.example .env.local   (macOS/Linux)
#   copy .env.local.example .env.local (Windows)
#
# Never commit `.env.local` or real API keys. Restart `npm run dev` after changes.
# Full setup, ESLint, and npm scripts: see README.md
#
# ─────────────────────────────────────────────────────────────────────────────
# Quick start (minimum to run a debate session)
# ─────────────────────────────────────────────────────────────────────────────
#   1. SESSION_SECRET          — always required (32+ random characters)
#   2. At least one LLM block  — see "LLM providers" below
#
# Login, dashboard history, and durable session storage also need Firebase and
# Cosmos DB (see those sections). The app can build without them; those features
# fail at runtime until configured.
# ─────────────────────────────────────────────────────────────────────────────


# =============================================================================
# LLM providers (configure at least one)
# =============================================================================
# Visionary, Critic, and most Judge calls use the first provider below whose
# required variables are all set. Order (do not reorder unless you intend to):
#   1. TerpAI  2. Anthropic  3. Google Gemini  4. OpenAI  5. Groq
#
# The Judge prefers Groq when GROQ_API_KEY is set (to spare quota on your main
# provider); otherwise it uses the same provider as the agents.


# --- TerpAI (OpenAI-compatible API) ---
# Required together to enable this provider. Both must be non-empty.
# TERPAI_API_KEY: API key from your TerpAI deployment.
TERPAI_API_KEY=
# TERPAI_BASE_URL: Base URL for chat completions (OpenAI-compatible), e.g.
# https://your-terpai-host/v1
TERPAI_BASE_URL=
# TERPAI_MODEL: Model id sent in API requests. Optional; defaults to gpt-4o.
TERPAI_MODEL=


# --- Anthropic Claude ---
# ANTHROPIC_API_KEY: Secret key from https://console.anthropic.com/
# Model is fixed in code: claude-sonnet-4-6
ANTHROPIC_API_KEY=


# --- Google Gemini ---
# GEMINI_API_KEY: API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL: Gemini model id. Optional; defaults to gemini-2.0-flash.
# Examples: gemini-2.0-flash, gemini-2.5-pro
GEMINI_MODEL=


# --- OpenAI ---
# OPENAI_API_KEY: Secret key from https://platform.openai.com/api-keys
# Model is fixed in code: gpt-4o
OPENAI_API_KEY=


# --- Groq ---
# GROQ_API_KEY: Secret key from https://console.groq.com/
# Used for the Judge when set; also available as the main provider if it is the
# only configured key. Model is fixed in code: llama-3.3-70b-versatile
GROQ_API_KEY=


# =============================================================================
# Session cookies (always required)
# =============================================================================
# Signs the httpOnly `__session` cookie after Firebase login. Server-only.
# Must be at least 32 characters. Generate with, e.g.:
#   openssl rand -base64 32
# Use a new random value per environment (local, staging, production).
SESSION_SECRET=


# =============================================================================
# Firebase Authentication (required for login and dashboard)
# =============================================================================
# Client config — embedded in the browser bundle (NEXT_PUBLIC_*). From Firebase
# Console → Project settings → Your apps → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Server-only: verifies Firebase ID tokens at POST /api/auth/session.
# Either:
#   • Paste the full service account JSON on one line (starts with "{"), or
#   • Set a path to a JSON file, e.g. ./firebase-service-account.json
# See firebase-service-account-example.json for the expected shape. Do not commit
# real credentials.
FIREBASE_SERVICE_ACCOUNT_KEY=


# =============================================================================
# Azure Cosmos DB for NoSQL (required for dashboard and durable sessions)
# =============================================================================
# Without these, live debates still work in memory, but listing sessions,
# reloading history, and background persistence will fail.
#
# Create a Cosmos account and two containers in the same database:
#   • Sessions container — partition key: /userId
#   • Messages container — partition key: /sessionId

# COSMOS_ENDPOINT: Account URI from Azure Portal → your Cosmos account → Keys.
COSMOS_ENDPOINT=https://YOUR_ACCOUNT.documents.azure.com:443/
# COSMOS_KEY: Primary or secondary key from the same Keys blade.
COSMOS_KEY=
# COSMOS_DATABASE: Database name. Optional; defaults to ricochet.
COSMOS_DATABASE=ricochet
# COSMOS_CONTAINER: Sessions/summaries container. Optional; defaults to sessions.
COSMOS_CONTAINER=sessions
# COSMOS_MESSAGES_CONTAINER: Per-message chat history. Optional; defaults to messages.
COSMOS_MESSAGES_CONTAINER=messages
