TERPAI_API_KEY=
TERPAI_BASE_URL=
# Optional OpenAI-compatible model id (defaults to gpt-4o if unset)
TERPAI_MODEL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Optional model id (defaults to gemini-2.0-flash). Example: gemini-2.5-pro
GEMINI_MODEL=
OPENAI_API_KEY=
GROQ_API_KEY=

# --- Session cookie signing (min 32 random characters; keep secret) ---
SESSION_SECRET=

# --- Firebase (client; safe to expose in browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# --- Firebase Admin (server only): paste full JSON OR path to service account file ---
# Example path: ./firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- Azure Cosmos DB for NoSQL (server only) ---
COSMOS_ENDPOINT=https://YOUR_ACCOUNT.documents.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=ricochet
# Session summaries for the dashboard (partition key: /userId)
COSMOS_CONTAINER=sessions
# Per-message chat history (partition key: /sessionId)
COSMOS_MESSAGES_CONTAINER=messages
